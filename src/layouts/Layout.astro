---
import "../../devlink/global.css"; // Webflow Styles
import {SiteShell} from "../components/SiteShell.tsx";
---

<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8"/>
    <meta name="viewport" content="width=device-width"/>
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}/eveandroque-fav.png`}/>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">
    <meta name="generator" content={Astro.generator}/>
    <title> Eve & Roque | Luxury Locations for Film, Events & Photoshoots </title>
</head>
<body>
<SiteShell client:load>
    <slot/>
</SiteShell>
</body>
</html>

<style>
    html,
    body {
        margin: 0;
        width: 100%;
        height: 100%;
    }
</style>
