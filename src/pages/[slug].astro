---
// src/pages/listings/[slug].astro
// Route: /listings/amber-estate
//
// Fully server-rendered — fetches property from Worker at request time.
// No client JS shipped for this page. Fast, SEO-friendly.

import Layout from '../layouts/Layout.astro';

import {getProperty, getAllSlugs} from '../lib/api';


const {slug} = Astro.params;

// Fetch property from Cloudflare Worker
const property = await getProperty(slug!);

// 404 if slug doesn't match any record
if (!property) {
    return Astro.redirect('/listings');
}
---

<Layout
        title={`${property.name} | Property Listings`}
        description={property.description ?? `${property.name} — ${property.city}. ${property.bedrooms} beds, ${property.bathrooms} baths, up to ${property.maxGuests} guests.`}
        ogImage={property.thumbnail}
>
    <div class="property-page">

        <!-- ── Back link ── -->
        <div class="property-page__nav">
            <a href="/listings" class="back-link">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                          stroke-linejoin="round"/>
                </svg>
                All properties
            </a>
        </div>

        <!-- ── Hero image ── -->
        <div class="property-page__hero">
            <img
                    src={property.thumbnail}
                    alt={property.name}
                    class="property-page__hero-img"
            />
        </div>

        <!-- ── Content ── -->
        <div class="property-page__content">

            <div class="property-page__main">

                <!-- Header -->
                <div class="property-page__header">
                    <div class="property-page__location">
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                            <path d="M7 1C4.79 1 3 2.79 3 5c0 2.97 4 8 4 8s4-5.03 4-8c0-2.21-1.79-4-4-4zm0 5.5A1.5 1.5 0 1 1 7 3.5a1.5 1.5 0 0 1 0 3z"
                                  fill="currentColor"/>
                        </svg>
                        {property.city}
                    </div>
                    <h1 class="property-page__name">{property.name}</h1>
                </div>

                <!-- Stats -->
                <div class="property-page__stats">
                    <div class="property-page__stat">
                        <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
                            <path d="M1 10V6.5C1 5.4 1.9 4.5 3 4.5H13C14.1 4.5 15 5.4 15 6.5V10M1 10H15M1 10V13M15 10V13M3 4.5V3C3 2.45 3.45 2 4 2H12C12.55 2 13 2.45 13 3V4.5"
                                  stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                        <span>{property.bedrooms} Bedrooms</span>
                    </div>
                    <div class="property-page__stat">
                        <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
                            <path d="M2 8H14V11C14 12.1 13.1 13 12 13H4C2.9 13 2 12.1 2 11V8ZM2 8V4C2 3.45 2.45 3 3 3V3C3.55 3 4 3.45 4 4V5.5"
                                  stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>
                        </svg>
                        <span>{property.bathrooms} Bathrooms</span>
                    </div>
                    {property.maxGuests && (
                            <div class="property-page__stat">
                                <svg width="18" height="18" viewBox="0 0 16 16" fill="none">
                                    <circle cx="8" cy="5" r="2.5" stroke="currentColor" stroke-width="1.2"/>
                                    <path d="M3 14c0-2.76 2.24-5 5-5s5 2.24 5 5" stroke="currentColor"
                                          stroke-width="1.2" stroke-linecap="round"/>
                                </svg>
                                <span>Up to {property.maxGuests} guests</span>
                            </div>
                    )}
                </div>

                <!-- Description -->
                {property.description && (
                        <div class="property-page__description">
                            <h2>About this property</h2>
                            <p>{property.description}</p>
                        </div>
                )}

                <!-- Amenities -->
                {property.amenities && property.amenities.length > 0 && (
                        <div class="property-page__amenities">
                            <h2>Amenities</h2>
                            <ul class="property-page__amenities-list">
                                {property.amenities.map(a => (
                                        <li>{a}</li>
                                ))}
                            </ul>
                        </div>
                )}

            </div>

            <!-- ── Sidebar / CTA ── -->
            <aside class="property-page__sidebar">
                <div class="property-page__cta-card">
                    <p class="property-page__cta-label">Interested in this property?</p>
                    <a href="/contact" class="property-page__cta-btn">
                        Request a booking
                    </a>
                    <a href="/listings" class="property-page__cta-secondary">
                        ← Browse more properties
                    </a>
                </div>
            </aside>

        </div>

        <!-- ── Gallery ── -->
        {property.gallery && property.gallery.length > 0 && (
                <div class="property-page__gallery">
                    <h2>Gallery</h2>
                    <div class="property-page__gallery-grid">
                        {property.gallery.map(img => (
                                <img src={img.url} alt={img.filename} loading="lazy"/>
                        ))}
                    </div>
                </div>
        )}

    </div>
</Layout>

<style>
    .property-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 24px 80px;
    }

    /* ── Nav ── */
    .property-page__nav {
        padding: 24px 0 0;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: #666;
        text-decoration: none;
        transition: color 0.15s;
    }

    .back-link:hover {
        color: #111;
    }

    /* ── Hero ── */
    .property-page__hero {
        margin: 24px 0 48px;
        border-radius: 10px;
        overflow: hidden;
        aspect-ratio: 16 / 7;
    }

    .property-page__hero-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    /* ── Content layout ── */
    .property-page__content {
        display: grid;
        grid-template-columns: 1fr 340px;
        gap: 64px;
        align-items: start;
    }

    @media (max-width: 860px) {
        .property-page__content {
            grid-template-columns: 1fr;
            gap: 40px;
        }
    }

    /* ── Header ── */
    .property-page__location {
        display: flex;
        align-items: center;
        gap: 5px;
        color: #777;
        font-size: 13px;
        margin-bottom: 10px;
    }

    .property-page__name {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: clamp(32px, 4vw, 48px);
        font-weight: 400;
        color: #111;
        margin: 0 0 32px;
        line-height: 1.1;
        letter-spacing: -0.02em;
    }

    /* ── Stats ── */
    .property-page__stats {
        display: flex;
        gap: 32px;
        padding: 24px 0;
        border-top: 1px solid #f0f0f0;
        border-bottom: 1px solid #f0f0f0;
        margin-bottom: 40px;
        flex-wrap: wrap;
    }

    .property-page__stat {
        display: flex;
        align-items: center;
        gap: 8px;
        font-size: 15px;
        color: #333;
    }

    /* ── Description ── */
    .property-page__description h2,
    .property-page__amenities h2,
    .property-page__gallery h2 {
        font-family: 'EB Garamond', Georgia, serif;
        font-size: 22px;
        font-weight: 400;
        color: #111;
        margin: 0 0 16px;
    }

    .property-page__description p {
        font-size: 15px;
        line-height: 1.7;
        color: #444;
        margin: 0 0 40px;
    }

    /* ── Amenities ── */
    .property-page__amenities-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 24px;
        list-style: none;
        padding: 0;
        margin: 0 0 40px;
    }

    .property-page__amenities-list li {
        font-size: 14px;
        color: #444;
        padding-left: 16px;
        position: relative;
    }

    .property-page__amenities-list li::before {
        content: '✓';
        position: absolute;
        left: 0;
        color: #111;
        font-size: 12px;
    }

    /* ── Sidebar ── */
    .property-page__cta-card {
        position: sticky;
        top: 32px;
        border: 1px solid #e2e2e2;
        border-radius: 10px;
        padding: 28px;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }

    .property-page__cta-label {
        font-size: 15px;
        font-weight: 500;
        color: #111;
        margin: 0;
    }

    .property-page__cta-btn {
        display: block;
        text-align: center;
        background: #111;
        color: #fff;
        padding: 14px;
        border-radius: 6px;
        font-size: 15px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.2s;
    }

    .property-page__cta-btn:hover {
        background: #333;
    }

    .property-page__cta-secondary {
        display: block;
        text-align: center;
        font-size: 13px;
        color: #888;
        text-decoration: none;
        transition: color 0.15s;
    }

    .property-page__cta-secondary:hover {
        color: #111;
    }

    /* ── Gallery ── */
    .property-page__gallery {
        margin-top: 64px;
    }

    .property-page__gallery-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
    }

    .property-page__gallery-grid img {
        width: 100%;
        aspect-ratio: 4 / 3;
        object-fit: cover;
        border-radius: 6px;
    }

    @media (max-width: 640px) {
        .property-page__gallery-grid {
            grid-template-columns: 1fr 1fr;
        }
    }
</style>