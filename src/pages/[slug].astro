---
// src/pages/listings/[slug].astro
// Route: /listings/rayen-villa
//
// Server-renders property header + meta, mounts PropertyApp React island
// for all interactive sections (gallery modal, form, map, related).

import Layout from '../layouts/Layout.astro';
import {PropertyApp} from '../components/propertyDetails/Propertyapp';

import {getProperty, getAllSlugs} from '../lib/api';

const {slug} = Astro.params;

const property = await getProperty(slug!);

if (!property) return Astro.redirect('/listings');

const workerUrl = import.meta.env.PUBLIC_WORKER_URL as string;
const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN as string;
const filloutUrl = import.meta.env.PUBLIC_FILLOUT_URL as string;

const ogDescription = `${property.name} in ${property.city}. ${property.bedrooms} beds, ${property.bathrooms} baths${property.eventMaxCap ? `, up to ${property.eventMaxCap} guests for events` : ''}.`;
---

<Layout
        title={`${property.name} | Eve & Roque`}
        description={property.description?.slice(0, 160) ?? ogDescription}
        ogImage={property.thumbnail}
>
    <div class="content-area">
        <!-- Back nav — server rendered, instant -->
        <div class="property-nav">
            <a href="/listings" class="property-nav__back" onclick="event.preventDefault(); history.back();">
                <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M10 4L6 8l4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"
                          stroke-linejoin="round"/>
                </svg>
                All properties
            </a>
        </div>

        <!--
          PropertyApp is a single React island that owns:
          - Gallery (with photo modal)
          - Property header + stats
          - Tab nav (Overview / Amenities)
          - Inquiry form (shared state with Additional Services)
          - Map (Mapbox)
          - Additional Services (selectable, feeds an inquiry form)
          - Fillout embed iframe
          - Related properties
        -->


        <PropertyApp
                client:load
                property={property}
                filloutUrl={filloutUrl}
                workerUrl={workerUrl}
                mapboxToken={mapboxToken}
        />
    </div>
</Layout>

<style>

    .content-area {
        padding-top: 5rem;
    }

    .property-nav {
        max-width: 90rem;
        margin: 0 auto;
        padding: 1.5rem 1.5rem 0;
    }

    .property-nav__back {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 14px;
        color: #666;
        text-decoration: none;
        font-family: 'DM Sans', sans-serif;
        transition: color 0.15s;
    }

    .property-nav__back:hover {
        color: #111;
    }

    @media (max-width: 480px) {
        .property-nav {
            padding: 1rem 1rem 1rem;
        }
    }

</style>