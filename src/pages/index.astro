---
import Layout from '../layouts/Layout.astro';
// import {Section, Container, Block, Link} from '.a./../devlink/_Builtin/index.js';
import {Header} from "../../devlink/Header";
import {Footer} from "../../devlink/Footer";
import ListingsApp from "../components/ListingsApp.tsx";
import {Navbar} from '../../devlink/Navbar';

const workerUrl = import.meta.env.PUBLIC_WORKER_URL;
---

<Layout>
    <div>
        <div class="content-area">
            <div class="listing-hero">
                <div class="hero-imgwrap">
                    <div class="hero-img-overlay"></div>
                    <img src="/listings/listing-img.webp" alt="Hero Image" class="hero-image" width="100%" height="100%"
                         fetchpriority="high" loading="eager">
                </div>
                <div class="hero-content">
                    <h1>Find Your Dream Property</h1>
                    <p>Explore a curated selection of stunning properties that cater to every taste and budget. Your
                        perfect getaway or investment opportunity awaits!</p>
                </div>
            </div>
            <ListingsApp client:load
                         baseApiUrl={workerUrl}
                         filtersApiUrl={`${workerUrl}/api/filters`}
            />
        </div>
    </div>
</Layout>

<style>

    .listing-hero {
        max-width: 85rem;
        width: 100%;
        margin: 0 auto;
        background-color: #f5f5f5;
        position: relative;
        padding-top: 12rem;
        padding-bottom: 12rem;
        border-radius: 0.25rem;
        overflow: hidden;
        margin-bottom: 2rem;

        & .hero-imgwrap {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            overflow: hidden;

            & .hero-img-overlay {
                position: absolute;
                width: 100%;
                height: 100%;
                z-index: 1;
                top: 0;
                left: 0;
                background: rgba(0, 0, 0, 0.5)
            }

            & img {
                object-fit: cover;
            }
        }

        & .hero-content {
            display: flex;
            gap: 1rem;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            text-align: center;
            padding: 0 1rem;
            max-width: 33.875rem;
            margin: 0 auto;
            width: 100%;
            position: relative;
            z-index: 1;
        }
    }

    h1 {
        font-size: 2.5rem;
        font-weight: 700;
        color: #ffffff;
    }

    p {
        color: #ffffff;
        line-height: 1.5;
    }

    .content-area {
        padding-top: 6rem;
        min-height: 100vh;
    }

    .button-primary {
        border-radius: 4px;
        background: #146ef5;
        color: #ffffff;
        box-shadow: 0px 0.5px 1px rgba(0, 0, 0, 0.25), inset 0px 29px 23px -16px rgba(255, 255, 255, 0.04), inset 0px 0.5px 0.5px rgba(255, 255, 255, 0.2);
    }

    .button-primary:hover {
        background: #2c80fd;
        color: #ffffff;
    }


    @media (max-width: 768px) {
        .listing-hero {
            padding-left: 1rem;
            padding-right: 1rem;
            padding-top: 5rem;
            padding-bottom: 5rem;
            border-radius: 0
        }

        .content-area {
            padding-top: 5rem;
        }
    }

</style>
